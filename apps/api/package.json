{
  "name": "@oes/api",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run build && node dist/index.js",
    "build": "tsup src/index.ts --format esm --target es2022 --platform node --out-dir dist --sourcemap",
    "start": "node dist/index.js",
    "lint": "node -e \"process.exit(0)\"",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1",
    "@supabase/supabase-js": "^2.103.0",
    "dotenv": "^17",
    "hono": "^4",
    "zod": "^4"
  },
  "devDependencies": {
    "tsup": "^8",
    "tsx": "^4",
    "typescript": "^5"
  }
}

